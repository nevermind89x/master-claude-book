---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as 'en' | 'es' | 'pt');

const downloadUrl = lang === 'es'
  ? '/downloads/mastering-claude-preview-es.pdf'
  : '/downloads/mastering-claude-preview-en.pdf';
---

<section id="free-preview" class="relative py-20 overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-violet-600 rounded-full blur-3xl opacity-5"></div>
  </div>

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-gradient-to-br from-white/5 to-white/[0.02] border border-white/10 rounded-3xl overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0">

        <!-- Left: text -->
        <div class="p-8 md:p-12 flex flex-col justify-center">
          <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/15 border border-emerald-500/30 text-emerald-400 text-xs font-semibold uppercase tracking-wider mb-6 w-fit">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
            {t('preview.badge')}
          </span>

          <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 leading-tight">
            {t('preview.title')}
          </h2>

          <p class="text-slate-400 text-sm leading-relaxed mb-8">
            {t('preview.subtitle')}
          </p>

          <p class="text-slate-500 text-xs font-semibold uppercase tracking-wider mb-4">
            {t('preview.includes')}
          </p>

          <ul class="space-y-2 mb-10">
            {[
              t('preview.item1'),
              t('preview.item2'),
              t('preview.item3'),
              t('preview.item4'),
            ].map((item) => (
              <li class="flex items-start gap-2.5 text-slate-300 text-sm">
                <svg class="w-4 h-4 text-emerald-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <a
            href={downloadUrl}
            download
            class="group inline-flex flex-col items-center justify-center gap-1 px-8 py-4 rounded-2xl bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-500 hover:to-teal-500 text-white font-semibold transition-all duration-200 shadow-lg shadow-emerald-500/20 w-full text-center"
          >
            <span class="flex items-center gap-2 text-base">
              <svg class="w-5 h-5 group-hover:-translate-y-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              {t('preview.cta')}
            </span>
            <span class="text-emerald-200 text-xs font-normal">{t('preview.cta_sub')}</span>
          </a>
        </div>

        <!-- Right: visual PDF preview mockup -->
        <div class="relative hidden md:flex items-center justify-center p-8 bg-gradient-to-br from-white/[0.03] to-transparent border-l border-white/10">
          <div class="relative w-52">
            <!-- Shadow stack -->
            <div class="absolute -bottom-3 -right-3 w-full h-full bg-violet-900/30 rounded-xl border border-white/5"></div>
            <div class="absolute -bottom-1.5 -right-1.5 w-full h-full bg-violet-800/20 rounded-xl border border-white/5"></div>

            <!-- Main card -->
            <div class="relative bg-[#0d0d1f] border border-white/15 rounded-xl overflow-hidden shadow-2xl">
              <!-- Mini cover bar -->
              <div class="h-28 bg-gradient-to-br from-violet-700 to-blue-800 flex items-center justify-center">
                <span class="text-white font-bold text-base tracking-tight text-center px-4 leading-tight">Mastering<br/>Claude</span>
              </div>
              <!-- Fake page lines -->
              <div class="p-4 space-y-1.5">
                {Array.from({ length: 8 }).map((_, i) => (
                  <div
                    class={`h-2 rounded-full bg-white/10 ${i === 0 ? 'w-4/5' : i % 3 === 0 ? 'w-3/5' : 'w-full'}`}
                  ></div>
                ))}
                <!-- Blurred section indicator -->
                <div class="mt-4 pt-3 border-t border-white/10 flex items-center gap-2">
                  <svg class="w-3.5 h-3.5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                  </svg>
                  <div class="space-y-1 flex-1">
                    <div class="h-1.5 rounded bg-white/5 w-full blur-[2px]"></div>
                    <div class="h-1.5 rounded bg-white/5 w-4/5 blur-[2px]"></div>
                  </div>
                </div>
              </div>
            </div>

            <!-- "FREE" badge -->
            <div class="absolute -top-3 -right-3 w-12 h-12 bg-emerald-500 rounded-full flex items-center justify-center shadow-lg shadow-emerald-500/40">
              <span class="text-white text-xs font-black">FREE</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
