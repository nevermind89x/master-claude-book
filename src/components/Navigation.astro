---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as 'en' | 'es' | 'pt');

const langSwitcher = [
  { code: 'en', label: 'EN', flag: '🇺🇸', path: '/' },
  { code: 'es', label: 'ES', flag: '🇪🇸', path: '/es/' },
  // PT hidden until translation is ready
  // { code: 'pt', label: 'PT', flag: '🇧🇷', path: '/pt/' },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-sm bg-[#05050f]/80 border-b border-white/10"
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href={lang === 'es' ? '/es/' : '/'} class="flex items-center gap-2 flex-shrink-0">
        <svg
          class="w-7 h-7"
          viewBox="0 0 28 28"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <defs>
            <linearGradient id="bookGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" style="stop-color:#8b5cf6" />
              <stop offset="100%" style="stop-color:#3b82f6" />
            </linearGradient>
          </defs>
          <rect x="4" y="2" width="16" height="22" rx="2" fill="url(#bookGrad)" opacity="0.9" />
          <rect x="6" y="2" width="16" height="22" rx="2" fill="url(#bookGrad)" />
          <line x1="9" y1="8" x2="19" y2="8" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.7" />
          <line x1="9" y1="12" x2="19" y2="12" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.7" />
          <line x1="9" y1="16" x2="15" y2="16" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.7" />
        </svg>
        <span
          class="font-bold text-lg bg-gradient-to-r from-violet-400 via-purple-400 to-blue-400 bg-clip-text text-transparent"
        >
          Mastering Claude
        </span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        <a href="#features" class="text-slate-400 hover:text-white transition-colors text-sm font-medium">
          {t('nav.features')}
        </a>
        <a href="#about" class="text-slate-400 hover:text-white transition-colors text-sm font-medium">
          {t('nav.about')}
        </a>
        <a href="#buy" class="text-slate-400 hover:text-white transition-colors text-sm font-medium">
          {t('nav.buy')}
        </a>
      </div>

      <div class="flex items-center gap-3">
        <div class="hidden sm:flex items-center gap-1 bg-white/5 border border-white/10 rounded-lg p-1">
          {
            langSwitcher.map((l) => (
              <a
                href={l.path}
                class={`flex items-center gap-1 px-2 py-1 rounded-md text-xs font-medium transition-all duration-200 ${
                  lang === l.code
                    ? 'bg-white/15 text-white'
                    : 'text-slate-400 hover:text-white hover:bg-white/10'
                }`}
              >
                <span>{l.flag}</span>
                <span>{l.label}</span>
              </a>
            ))
          }
        </div>

        <a
          href="#buy"
          class="hidden md:inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-gradient-to-r from-violet-600 to-blue-600 text-white font-semibold text-sm hover:from-violet-500 hover:to-blue-500 transition-all duration-200 shadow-lg shadow-violet-500/25"
        >
          {t('nav.cta')}
        </a>

        <label for="mobile-menu-toggle" class="md:hidden cursor-pointer p-2 text-slate-400 hover:text-white">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </label>
      </div>
    </div>

    <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
    <div
      class="md:hidden hidden peer-checked:block border-t border-white/10 py-4"
    >
      <div class="flex flex-col gap-3">
        <a href="#features" class="text-slate-400 hover:text-white transition-colors text-sm font-medium px-1">
          {t('nav.features')}
        </a>
        <a href="#about" class="text-slate-400 hover:text-white transition-colors text-sm font-medium px-1">
          {t('nav.about')}
        </a>
        <a href="#buy" class="text-slate-400 hover:text-white transition-colors text-sm font-medium px-1">
          {t('nav.buy')}
        </a>
        <div class="flex items-center gap-1 pt-2 border-t border-white/10">
          {
            langSwitcher.map((l) => (
              <a
                href={l.path}
                class={`flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${
                  lang === l.code
                    ? 'bg-white/15 text-white'
                    : 'text-slate-400 hover:text-white hover:bg-white/10'
                }`}
              >
                <span>{l.flag}</span>
                <span>{l.label}</span>
              </a>
            ))
          }
        </div>
        <a
          href="#buy"
          class="inline-flex items-center justify-center gap-2 px-4 py-2 rounded-lg bg-gradient-to-r from-violet-600 to-blue-600 text-white font-semibold text-sm hover:from-violet-500 hover:to-blue-500 transition-all duration-200"
        >
          {t('nav.cta')}
        </a>
      </div>
    </div>
  </nav>
</header>
