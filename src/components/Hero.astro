---
import { useTranslations } from '../i18n/utils';
import { GUMROAD_URL_EN, GUMROAD_URL_ES, LEMONSQUEEZY_URL_EN, LEMONSQUEEZY_URL_ES } from '../constants';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as 'en' | 'es' | 'pt');

const gumroadUrl = lang === 'es' ? GUMROAD_URL_ES : GUMROAD_URL_EN;
const lsUrl = lang === 'es' ? LEMONSQUEEZY_URL_ES : LEMONSQUEEZY_URL_EN;
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-violet-600 rounded-full blur-3xl opacity-20"></div>
    <div class="absolute top-1/4 right-1/4 w-64 h-64 bg-blue-600 rounded-full blur-3xl opacity-15"></div>
    <div class="absolute bottom-1/4 left-1/3 w-80 h-80 bg-purple-600 rounded-full blur-3xl opacity-10"></div>
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-24">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-sm text-slate-300 mb-8 backdrop-blur-sm">
      <span class="w-2 h-2 rounded-full bg-violet-400 animate-pulse-slow"></span>
      🤖 {t('hero.badge')}
    </div>

    <h1 class="font-bold tracking-tight mb-6">
      <span class="block text-5xl md:text-7xl bg-gradient-to-r from-violet-400 via-purple-400 to-blue-400 bg-clip-text text-transparent leading-tight">
        {t('hero.headline1')}
      </span>
      <span class="block text-5xl md:text-7xl bg-gradient-to-r from-violet-400 via-purple-400 to-blue-400 bg-clip-text text-transparent leading-tight">
        {t('hero.headline2')}
      </span>
    </h1>

    <p class="text-slate-300 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
      {t('hero.subtitle')}
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
      <!-- Primary: Gumroad -->
      <a
        href={gumroadUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-gradient-to-r from-violet-600 to-blue-600 text-white font-semibold text-lg hover:from-violet-500 hover:to-blue-500 transition-all duration-200 shadow-lg shadow-violet-500/25"
      >
        <!-- Gumroad G icon -->
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zm.5 17.5h-1.75A3.75 3.75 0 017 13.75v-3.5A3.75 3.75 0 0110.75 6.5H13a3 3 0 013 3v.5h-2v-.5a1 1 0 00-1-1h-2.25A1.75 1.75 0 009 10.25v3.5a1.75 1.75 0 001.75 1.75H12.5v-2H11v-2h3.5v4.5a.5.5 0 01-.5.5h-1.5z"/>
        </svg>
        {t('hero.cta_primary')}
      </a>

      <!-- Secondary: Lemon Squeezy -->
      <a
        href={lsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-xl border border-white/20 text-white font-semibold text-lg hover:bg-white/10 transition-all duration-200"
      >
        <span class="text-xl">🍋</span>
        {t('hero.cta_secondary')}
      </a>
    </div>

    <p class="text-slate-500 text-sm mb-16">
      {t('hero.available')}
      <a href="/" class={`mx-1 hover:text-slate-300 transition-colors ${lang === 'en' ? 'text-white font-medium' : 'text-slate-500'}`}>
        {t('hero.available_en')}
      </a>
      ·
      <a href="/es/" class={`mx-1 hover:text-slate-300 transition-colors ${lang === 'es' ? 'text-white font-medium' : 'text-slate-500'}`}>
        {t('hero.available_es')}
      </a>
    </p>

    <div class="grid grid-cols-3 gap-4 max-w-lg mx-auto">
      {
        [
          { label: t('hero.stat1'), icon: '⚡' },
          { label: t('hero.stat2'), icon: '🌍' },
          { label: t('hero.stat3'), icon: '📖' },
        ].map((stat) => (
          <div class="bg-white/5 border border-white/10 rounded-xl p-4 backdrop-blur-sm text-center">
            <div class="text-2xl mb-1">{stat.icon}</div>
            <div class="text-xs text-slate-400 font-medium leading-tight">{stat.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
