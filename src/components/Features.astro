---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as 'en' | 'es' | 'pt');

const featureIcons = [
  `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>`,
  `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 12.75c1.148 0 2.278.08 3.383.237 1.037.146 1.866.966 1.866 2.013 0 3.728-2.35 6.75-5.25 6.75S6.75 18.728 6.75 15c0-1.046.83-1.867 1.866-2.013A23.97 23.97 0 0112 12.75zm0 0c2.883 0 5.647.508 8.207 1.44a23.91 23.91 0 01-1.152 6.06M12 12.75c-2.883 0-5.647.508-8.208 1.44a23.91 23.91 0 001.153 6.06M12 12.75a2.25 2.25 0 002.248-2.354M12 12.75a2.25 2.25 0 01-2.248-2.354M12 8.25c.994 0 1.95-.138 2.852-.398m-5.704 0A22.52 22.52 0 0112 8.25m0 0c2.883 0 5.647.508 8.207 1.44a23.91 23.91 0 01-1.152 6.06" /></svg>`,
  `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
  `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z" /></svg>`,
  `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5" /></svg>`,
];

const features = [
  { key: 'item1', color: 'from-violet-500/20 to-purple-500/10', border: 'border-violet-500/20' },
  { key: 'item2', color: 'from-blue-500/20 to-cyan-500/10', border: 'border-blue-500/20' },
  { key: 'item3', color: 'from-emerald-500/20 to-teal-500/10', border: 'border-emerald-500/20' },
  { key: 'item4', color: 'from-orange-500/20 to-amber-500/10', border: 'border-orange-500/20' },
  { key: 'item5', color: 'from-rose-500/20 to-pink-500/10', border: 'border-rose-500/20' },
  { key: 'item6', color: 'from-violet-500/20 to-blue-500/10', border: 'border-violet-500/20' },
];
---

<section id="features" class="relative py-24 overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-0 w-96 h-96 bg-violet-600 rounded-full blur-3xl opacity-5"></div>
    <div class="absolute top-1/4 right-0 w-96 h-96 bg-blue-600 rounded-full blur-3xl opacity-5"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2
        class="text-3xl md:text-4xl font-bold tracking-tight bg-gradient-to-r from-violet-400 via-purple-400 to-blue-400 bg-clip-text text-transparent mb-4"
      >
        {t('features.title')}
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        {t('features.subtitle')}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        features.map((feature, index) => (
          <div
            class={`group bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 hover:bg-white/8 hover:border-white/20 transition-all duration-300`}
          >
            <div
              class={`inline-flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br ${feature.color} border ${feature.border} text-white mb-4`}
              set:html={featureIcons[index]}
            />
            <h3 class="text-white font-semibold text-lg mb-2">
              {t(`features.${feature.key}_title`)}
            </h3>
            <p class="text-slate-400 text-sm leading-relaxed">
              {t(`features.${feature.key}_desc`)}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
